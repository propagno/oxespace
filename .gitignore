# OXESpace writes the internal MCP bridge config here with a live local token —
# never commit it (secret). The app also auto-appends this to each workspace's
# .gitignore when it writes the file (see mcp-sync.service.ts).
.mcp.json

# Bundled semantic model — fetched at build time (npm run prepare:model),
