{
  "name": "oxespace",
  "version": "0.2.4",
  "description": "An open source, AI-native workspace and terminal",
  "repository": {
    "type": "git",
    "url": "https://github.com/propagno/oxespace.git"
  },
  "homepage": "https://github.com/propagno/oxespace#readme",
  "bugs": {
    "url": "https://github.com/propagno/oxespace/issues"
  },
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "prepare:model": "node scripts/fetch-semantic-model.mjs",
    "dist": "npm run prepare:model && npm run build && npm run fix:native && electron-builder --win --config.npmRebuild=false",
    "rebuild:native": "electron-rebuild -f -w node-pty,better-sqlite3",
    "fix:native": "node scripts/fix-native-modules.mjs",
    "generate:icon": "node scripts/generate-icon.mjs"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@monaco-editor/react": "^4.7.0",
    "@xenova/transformers": "^2.17.2",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-unicode11": "^0.8.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^5.5.0",
    "@xyflow/react": "^12.10.2",
    "chokidar": "^5.0.0",
    "electron-log": "^5.4.3",
    "electron-store": "^8.2.0",
    "ignore": "^7.0.5",
    "jsonc-parser": "^3.3.1",
    "lucide-react": "^0.468.0",
    "monaco-editor": "^0.55.1",
    "picomatch": "^4.0.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-resizable-panels": "^2.1.7",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "0.25.9",
    "zustand": "^4.5.5"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.9.0",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@playwright/test": "^1.59.1",
    "@resvg/resvg-js": "^2.6.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^31.7.7",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "gpt-tokenizer": "^3.4.0",
    "jsdom": "^25.0.1",
    "png-to-ico": "^3.0.1",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
