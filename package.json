{
  "name": "oxespace",
  "version": "0.4.0",
  "description": "An open source, AI-native workspace and terminal",
  "repository": {
    "type": "git",
    "url": "https://github.com/propagno/oxespace.git"
  },
  "homepage": "https://github.com/propagno/oxespace#readme",
  "bugs": {
    "url": "https://github.com/propagno/oxespace/issues"
  },
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && npm run verify:bundle",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src electron shared tests e2e scripts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "bench:cpu": "vitest bench --run tests/bench/hotpaths.bench.ts",
    "bench:services": "vitest bench --run tests/bench/services.bench.ts",
    "bench:ui": "playwright test --config playwright.tools.config.ts perf-benchmark.spec.ts",
    "bench:semantic": "node scripts/semantic-eval.mjs",
    "bench:semantic:gate": "node scripts/semantic-quality-gate.mjs",
    "shots:ui": "playwright test --config playwright.tools.config.ts screenshots.spec.ts",
    "prepare:model": "node scripts/fetch-semantic-model.mjs",
    "postinstall": "npm run rebuild:native",
    "dist": "npm run prepare:model && npm run build && npm run fix:native && npm run slim:pack && electron-builder --win --config.npmRebuild=false --publish never",
    "rebuild:native": "electron-rebuild -f -w node-pty,better-sqlite3",
    "rebuild:native:electron": "electron-rebuild -f -w node-pty,better-sqlite3",
    "rebuild:native:node": "npm rebuild better-sqlite3 node-pty",
    "verify:native": "node scripts/run-native-verification.mjs",
    "native:doctor": "node scripts/native-doctor.mjs",
    "verify:bundle": "node scripts/verify-bundle-budgets.mjs",
    "fix:native": "node scripts/fix-native-modules.mjs",
    "slim:pack": "node scripts/slim-pack-deps.mjs",
    "generate:icon": "node scripts/generate-icon.mjs",
    "test:smoke": "playwright test e2e/smoke-hub.spec.ts",
    "release:checksums": "node scripts/release-checksums.mjs"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/vite": "^4.3.3",
    "@vscode/ripgrep": "^1.18.0",
    "@xenova/transformers": "^2.17.2",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-unicode11": "^0.8.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^5.5.0",
    "@xyflow/react": "^12.10.2",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "electron-log": "^5.4.3",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9",
    "geist": "^1.7.2",
    "ignore": "^7.0.5",
    "jsonc-parser": "^3.3.1",
    "lucide-react": "^0.468.0",
    "monaco-editor": "^0.55.1",
    "picomatch": "^4.0.4",
    "radix-ui": "^1.6.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-resizable-panels": "^2.1.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.3",
    "tree-sitter-wasms": "^0.1.13",
    "tw-animate-css": "^1.4.0",
    "web-tree-sitter": "0.25.9",
    "zustand": "^4.5.5"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.9.0",
    "node-pty": "^1.0.0"
  },
  "overrides": {
    "dompurify": "3.4.12",
    "protobufjs": "7.6.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.59.1",
    "@resvg/resvg-js": "^2.6.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.9",
    "electron": "^31.7.7",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "gpt-tokenizer": "^3.4.0",
    "jsdom": "^25.0.1",
    "png-to-ico": "^3.0.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.65.0",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
